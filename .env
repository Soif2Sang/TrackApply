# ============================================
# Job Application Tracker - Environment Variables
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Port for the server to run on (default: 3002)
PORT=3002

# Database connection URL
# Format: postgresql://user:password@host:port/database
# Use 'postgres' as host when running in Docker, 'localhost' when running locally
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/soif2sang

# --------------------------------------------
# Authentication (Better Auth)
# --------------------------------------------
# Secret key for JWT signing (generate a secure random string)
BETTER_AUTH_SECRET=your-secret-key-here

# Base URL for the auth server (where the API is hosted)
BETTER_AUTH_URL=http://localhost:3002

# CORS origin (where the web app is hosted)
CORS_ORIGIN=http://localhost:3003

# --------------------------------------------
# Google OAuth (for Google Sign-In)
# --------------------------------------------
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=358809226350-ahuufgip636p1ksrj5hslscdehg6ucuf.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

GMAIL_CLIENT_ID=358809226350-ahuufgip636p1ksrj5hslscdehg6ucuf.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=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
GMAIL_REDIRECT_URI=http://localhost:3002/auth/gmail/callback

# --------------------------------------------
# Web Client Configuration
# --------------------------------------------
# URL of the server API (used by web app to make requests)
# This should point to the server URL
VITE_SERVER_URL=http://localhost:3002

# Alternative/legacy naming (also supported)
VITE_API_URL=http://localhost:3002

# --------------------------------------------
# Gmail API Configuration (for email processing)
# --------------------------------------------
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# You need to enable Gmail API and create OAuth 2.0 credentials
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/gmail/callback

# --------------------------------------------
# Pub/Sub Configuration (for Gmail push notifications)
# --------------------------------------------
# Verification token for Pub/Sub push notifications
PUBSUB_VERIFICATION_TOKEN=3VFMEfFO1SxfGl5YAhiz0A0WEpPGO2Gf7V6CfRhgQb6F3W4vUset6P0Z1wWuh1qD

# --------------------------------------------
# Gemini API Configuration (for email classification)
# --------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDaA4ssnSQYfIoM50t7NKz6lOQF1oC2a-g

# --------------------------------------------
# Gmail Label IDs (optional, will use defaults if not set)
# --------------------------------------------
# You can get these IDs from Gmail API or set them manually
# LABEL_RECRUITMENT_ACK=Label_RECRUITMENT_ACK
# LABEL_NEXT_STEP=Label_NEXT_STEP
# LABEL_DISAPPROVAL=Label_DISAPPROVAL
# LABEL_LOW_CONFIDENCE=Label_LOW_CONFIDENCE

# --------------------------------------------
# Email Processing Configuration
# --------------------------------------------
# Number of emails to sync in one batch (default: 50)
EMAIL_SYNC_BATCH_SIZE=50
# Maximum age in days for email sync (default: 90)
EMAIL_SYNC_MAX_AGE_DAYS=90
