# ============================================
# Web Client Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# Variables prefixed with VITE_ are exposed to the client-side code

# --------------------------------------------
# API Configuration
# --------------------------------------------
# Server URL - points to the backend API server (port 3002)
# This is used by the auth client and tRPC client
VITE_SERVER_URL=http://localhost:3002

# Alternative naming (kept for compatibility)
VITE_API_URL=http://localhost:3002

# --------------------------------------------
# Node Environment
# --------------------------------------------
# Node environment setting (development, production, test)
# This affects various behaviors like cookie security settings
NODE_ENV=development
