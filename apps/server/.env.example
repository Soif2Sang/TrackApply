# ============================================
# Server Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=3002

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/soif2sang

# PostgreSQL Docker configuration (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=soif2sang
POSTGRES_PORT=5432

# --------------------------------------------
# Authentication (Better Auth)
# --------------------------------------------
# Secret key for JWT signing (generate a secure random string, min 32 chars)
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production

# Base URL for the auth server (where the API is hosted)
BETTER_AUTH_URL=http://localhost:3002

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
# URL of the web frontend (for CORS and trusted origins)
# Can be comma-separated for multiple origins
CORS_ORIGIN=http://localhost:3003

# --------------------------------------------
# Google OAuth (for Google Sign-In)
# --------------------------------------------
# Get these from: https://console.cloud.google.com/apis/credentials
# Redirect URI should be: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --------------------------------------------
# Gmail API Configuration (for email processing)
# --------------------------------------------
# Optional dedicated Gmail OAuth credentials.
# If not set, the server will fall back to GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Redirect URI for Gmail OAuth callback
# If not set, the server will fall back to GOOGLE_REDIRECT_URI.
GMAIL_REDIRECT_URI=http://localhost:3002/auth/gmail/callback

# Alternative redirect URI naming (also supported)
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/gmail/callback

# --------------------------------------------
# Pub/Sub Configuration (for Gmail push notifications)
# --------------------------------------------
# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Verification token for Pub/Sub push notifications
# Generate a secure random string for this
PUBSUB_VERIFICATION_TOKEN=your-random-secret-token-min-32-chars

# --------------------------------------------
# Gemini AI Configuration (for email classification)
# --------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Gemini model to use for email classification (optional, defaults to gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# --------------------------------------------
# Gmail Label IDs (optional, will use defaults if not set)
# --------------------------------------------
# You can get these IDs from Gmail API or set them manually
LABEL_RECRUITMENT_ACK=Label_RECRUITMENT_ACK
LABEL_NEXT_STEP=Label_NEXT_STEP
LABEL_DISAPPROVAL=Label_DISAPPROVAL
LABEL_LOW_CONFIDENCE=Label_LOW_CONFIDENCE

# --------------------------------------------
# Email Processing Configuration
# --------------------------------------------
# Number of emails to sync in one batch (default: 50)
EMAIL_SYNC_BATCH_SIZE=50

# Maximum age in days for email sync (default: 90)
EMAIL_SYNC_MAX_AGE_DAYS=90

# Page size for email sync queries (default: 100)
EMAIL_SYNC_PAGE_SIZE=100

# Maximum total emails to sync per run, 0 for unlimited (default: 0)
EMAIL_SYNC_MAX_TOTAL=0

# --------------------------------------------
# Job Queue Configuration (PG-Boss)
# --------------------------------------------
# Concurrency for processing email jobs (default: 2)
PROCESS_EMAIL_CONCURRENCY=2

# Concurrency for analyzing content jobs (default: 2)
ANALYZE_CONTENT_CONCURRENCY=2

# Concurrency for labeling email jobs (default: 4)
LABEL_EMAIL_CONCURRENCY=4

# --------------------------------------------
# Retry Configuration
# --------------------------------------------
# Maximum retry attempts for analyze jobs (default: 5)
ANALYZE_RETRY_LIMIT=5

# Delay between retry attempts in seconds (default: 30)
ANALYZE_RETRY_DELAY_SECONDS=30

# --------------------------------------------
# Web Client Configuration
# --------------------------------------------
# URL of the server API (used by web app to make requests)
VITE_SERVER_URL=http://localhost:3002

# Alternative/legacy naming (also supported)
VITE_API_URL=http://localhost:3002

# Node environment (development, production, test)
NODE_ENV=development
