# ============================================
# Server Environment Variables
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=3002

# --------------------------------------------
# Database
# --------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/boilerplate

# --------------------------------------------
# Authentication (Better Auth)
# --------------------------------------------
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
BETTER_AUTH_URL=http://localhost:3002

# --------------------------------------------
# CORS
# --------------------------------------------
# URL of the web frontend (for CORS and trusted origins)
CORS_ORIGIN=http://localhost:3003

# --------------------------------------------
# Google OAuth (Optional - for Google Sign-In)
# --------------------------------------------
# Get these from: https://console.cloud.google.com/apis/credentials
# Redirect URI should be: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# --------------------------------------------
# Gmail API Configuration (for email processing)
# --------------------------------------------
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# You need to enable Gmail API and create OAuth 2.0 credentials
GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:3002/auth/gmail/callback

# --------------------------------------------
# Pub/Sub Configuration (for Gmail push notifications)
# --------------------------------------------
# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id
# Verification token for Pub/Sub push notifications
PUBSUB_VERIFICATION_TOKEN=your-random-secret-token

# --------------------------------------------
# Gemini API Configuration (for email classification)
# --------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# --------------------------------------------
# Gmail Label IDs (optional, will use defaults if not set)
# --------------------------------------------
# You can get these IDs from Gmail API or set them manually
# LABEL_RECRUITMENT_ACK=Label_RECRUITMENT_ACK
# LABEL_NEXT_STEP=Label_NEXT_STEP
# LABEL_DISAPPROVAL=Label_DISAPPROVAL
# LABEL_LOW_CONFIDENCE=Label_LOW_CONFIDENCE

# --------------------------------------------
# Email Processing Configuration
# --------------------------------------------
# Number of emails to sync in one batch (default: 50)
EMAIL_SYNC_BATCH_SIZE=50
# Maximum age in days for email sync (default: 90)
EMAIL_SYNC_MAX_AGE_DAYS=90
